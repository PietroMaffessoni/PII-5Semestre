    }
  ],
  "tables": [
    {
      "name": "AFKO",
      "module": "PP",
      "domain": "producao",
      "description": "Cabecalho das ordens de producao",
      "business_terms": ["producao", "ordem", "planta", "volume produzido", "data de inicio", "quantidade planejada"],
      "join_keys": ["AUFNR", "WERKS"],
      "fields": [
        {"name": "AUFNR", "label": "ordem_producao", "type": "text", "description": "Numero da ordem de producao"},
        {"name": "WERKS", "label": "planta", "type": "text", "description": "Codigo da planta"},
        {"name": "GSTRP", "label": "data_inicio", "type": "date", "description": "Data de inicio da ordem"},
        {"name": "GLTRP", "label": "data_fim", "type": "date", "description": "Data de fim da ordem"},
        {"name": "GAMNG", "label": "volume_producao", "type": "number", "description": "Quantidade total planejada/produzida"}
      ]
    },
    {
      "name": "AFPO",
      "module": "PP",
      "domain": "producao",
      "description": "Itens da ordem de producao",
      "business_terms": ["material produzido", "item da ordem", "quantidade da ordem"],
      "join_keys": ["AUFNR", "MATNR"],
      "fields": [
        {"name": "AUFNR", "label": "ordem_producao", "type": "text", "description": "Numero da ordem de producao"},
