        {"name": "FKIMG", "label": "quantidade_faturada", "type": "number", "description": "Quantidade faturada"},
        {"name": "NETWR", "label": "valor_faturado", "type": "number", "description": "Valor liquido do item"}
      ]
    },
    {
      "name": "EKKO",
      "module": "MM",
      "domain": "compras",
      "description": "Cabecalho do pedido de compra",
