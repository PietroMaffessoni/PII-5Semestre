      "join_keys": ["VBELN", "KUNNR"],
      "fields": [
        {"name": "VBELN", "label": "documento_faturamento", "type": "text", "description": "Numero do documento de faturamento"},
        {"name": "FKDAT", "label": "data_faturamento", "type": "date", "description": "Data de faturamento"},
        {"name": "KUNNR", "label": "cliente", "type": "text", "description": "Codigo do cliente"},
        {"name": "VKORG", "label": "organizacao_vendas", "type": "text", "description": "Organizacao de vendas"}
